---
import { addOnCatalogue } from '@/configuration/catalogues/add-ons';
import type {
  AddOnDefinition,
  ProductOfferingAddOnConfiguration,
} from '@/domain/add-ons';
import type { ProductOfferingDefinition } from '@/domain/offerings';
import type { OptionGroup } from '@/domain/option-groups';

const { offering } = Astro.props as { offering: ProductOfferingDefinition };

const optionGroups = [...offering.optionGroups].sort(
  (current, next) => current.displayOrder - next.displayOrder,
);

interface ResolvedAddOn {
  configuration: ProductOfferingAddOnConfiguration;
  definition: AddOnDefinition;
}

const addOns: ResolvedAddOn[] = offering.addOns
  .flatMap((configuration) => {
    const definition = addOnCatalogue.find(
      ({ id }) => id === configuration.addOnId,
    ) as AddOnDefinition | undefined;

    return definition ? [{ configuration, definition }] : [];
  })
  .sort(
    (current, next) =>
      current.configuration.displayOrder - next.configuration.displayOrder,
  );

function formatAud(cents: number) {
  return new Intl.NumberFormat('en-AU', {
    style: 'currency',
    currency: 'AUD',
  }).format(cents / 100);
}

function fieldId(group: OptionGroup) {
  return `field-${group.id}`;
}

function fieldLabelId(group: OptionGroup) {
  return `${group.id}-label`;
}

function fieldDescriptionId(group: OptionGroup) {
  return `${group.id}-description`;
}

function fieldMessageId(group: OptionGroup) {
  return `${group.id}-message`;
}

function fieldContentId(group: OptionGroup) {
  return `${group.id}-content`;
}

function hasFieldMessage(group: OptionGroup) {
  return group.id !== 'custom-colours-description';
}

function isCollapsibleOptionalGroup(group: OptionGroup) {
  return !group.required && group.id !== 'custom-colours-description';
}

const primaryOptionGroups = optionGroups.filter(
  (group) => !isCollapsibleOptionalGroup(group),
);

const personalisationOptionGroups = optionGroups.filter((group) =>
  isCollapsibleOptionalGroup(group),
);

function describedBy(group: OptionGroup) {
  return [
    group.description ? fieldDescriptionId(group) : undefined,
    hasFieldMessage(group) ? fieldMessageId(group) : undefined,
  ]
    .filter(Boolean)
    .join(' ');
}
---

{
  primaryOptionGroups.length > 0 && (
    <section
      class="configuration-section configuration-section--essentials"
      aria-labelledby="product-configuration-heading"
    >
      <div class="configuration-section-header">
        <p class="configuration-kicker">Step 1</p>
        <h3 id="product-configuration-heading" class="configuration-title">
          Product Configuration
        </h3>
        <p class="configuration-description">
          Start with the essentials that shape the product, price and production
          requirements.
        </p>
      </div>

      <div class="configuration-grid">
        {primaryOptionGroups.map((group) => (
          <div
            class={`configuration-field group conditional-field-panel ${
              group.id === 'custom-colours-description'
                ? 'conditional-field-panel--hidden'
                : ''
            }`}
            data-option-group-panel={group.id}
            hidden={group.id === 'custom-colours-description'}
            aria-hidden={
              group.id === 'custom-colours-description' ? 'true' : undefined
            }
          >
            <div class="space-y-2">
              <p
                id={fieldLabelId(group)}
                class="configuration-field-title flex flex-wrap items-center gap-2"
              >
                <span>{group.label}</span>
                {group.required && (
                  <>
                    <span class="sr-only"> required</span>
                    <span
                      aria-hidden="true"
                      class="rounded-full bg-rosa-claro px-2.5 py-1 text-xs font-semibold text-slate-700"
                    >
                      Required
                    </span>
                  </>
                )}
              </p>
            </div>
            <hr class="configuration-field-divider" />

            <div id={fieldContentId(group)} class="configuration-field-body">
              {group.description && (
                <p
                  id={fieldDescriptionId(group)}
                  class="form-message form-message--help"
                >
                  {group.description}
                </p>
              )}
              {(() => {
                switch (group.kind) {
                  case 'single-select':
                  case 'priced-single-select':
                    return (
                      <select
                        id={fieldId(group)}
                        name={group.id}
                        required={group.required}
                        class="form-control form-control--soft text-sm"
                        data-option-group={group.id}
                        data-option-kind={group.kind}
                        aria-labelledby={fieldLabelId(group)}
                        aria-describedby={describedBy(group)}
                      >
                        {!group.defaultValue && (
                          <option value="">Select an option</option>
                        )}
                        {group.options.map((option) => (
                          <option
                            value={option.value}
                            selected={group.defaultValue === option.value}
                            data-label={option.label}
                            data-price={
                              'price' in option ? option.price : undefined
                            }
                          >
                            {option.label}
                            {'price' in option
                              ? ` - ${formatAud(option.price)}`
                              : ''}
                            {option.description
                              ? ` (${option.description})`
                              : ''}
                          </option>
                        ))}
                      </select>
                    );

                  case 'multi-select':
                    return (
                      <div
                        class="option-choice-list"
                        role="group"
                        aria-labelledby={fieldLabelId(group)}
                        aria-describedby={describedBy(group)}
                        data-option-group={group.id}
                        data-option-kind={group.kind}
                        data-minimum-selections={group.minimumSelections}
                        data-maximum-selections={group.maximumSelections}
                      >
                        {group.options.map((option) => (
                          <label class="option-choice">
                            <input
                              type="checkbox"
                              name={group.id}
                              value={option.value}
                              data-label={option.label}
                              class="rounded border-slate-300"
                              aria-describedby={describedBy(group)}
                            />
                            <span>{option.label}</span>
                          </label>
                        ))}
                      </div>
                    );

                  case 'text':
                    return group.multiline ? (
                      <textarea
                        id={fieldId(group)}
                        name={group.id}
                        required={group.required}
                        maxlength={group.maxLength}
                        rows="3"
                        class="form-control form-control--soft text-sm resize-none"
                        data-option-group={group.id}
                        data-option-kind={group.kind}
                        aria-labelledby={fieldLabelId(group)}
                        aria-describedby={describedBy(group)}
                      />
                    ) : (
                      <input
                        id={fieldId(group)}
                        type="text"
                        name={group.id}
                        required={group.required}
                        maxlength={group.maxLength}
                        class="form-control form-control--soft text-sm"
                        data-option-group={group.id}
                        data-option-kind={group.kind}
                        aria-labelledby={fieldLabelId(group)}
                        aria-describedby={describedBy(group)}
                      />
                    );

                  case 'date':
                    return (
                      <input
                        id={fieldId(group)}
                        type="date"
                        name={group.id}
                        required={group.required}
                        class="form-control form-control--soft text-sm"
                        data-option-group={group.id}
                        data-option-kind={group.kind}
                        aria-labelledby={fieldLabelId(group)}
                        aria-describedby={describedBy(group)}
                      />
                    );
                }
              })()}

              {hasFieldMessage(group) && (
                <p
                  id={fieldMessageId(group)}
                  class="form-message form-message--help pt-1"
                  data-field-message={group.id}
                  aria-live="polite"
                />
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}

{
  personalisationOptionGroups.length > 0 && (
    <section
      class="configuration-section configuration-section--personalisation"
      aria-labelledby="personalisation-details-heading"
    >
      <div class="configuration-section-header">
        <p class="configuration-kicker">Step 2</p>
        <h3 id="personalisation-details-heading" class="configuration-title">
          Personalisation Details
        </h3>
        <p class="configuration-description">
          Add extra details only when they help us understand your preferred
          design, message or finishing touches.
        </p>
      </div>

      <div class="personalisation-stack">
        {personalisationOptionGroups.map((group) => (
          <div
            class={`optional-field-card group conditional-field-panel ${
              isCollapsibleOptionalGroup(group)
                ? 'optional-field-card--collapsed'
                : ''
            } ${
              group.id === 'custom-colours-description'
                ? 'conditional-field-panel--hidden'
                : ''
            }`}
            data-option-group-panel={group.id}
            data-optional-field-panel={
              isCollapsibleOptionalGroup(group) ? group.id : undefined
            }
            hidden={group.id === 'custom-colours-description'}
            aria-hidden={
              group.id === 'custom-colours-description' ? 'true' : undefined
            }
          >
            <button
              id={fieldLabelId(group)}
              type="button"
              class="optional-field-toggle"
              aria-expanded="false"
              aria-controls={fieldContentId(group)}
              data-optional-field-toggle={group.id}
            >
              <span>{group.label}</span>
              <span class="optional-field-chevron" aria-hidden="true">
                &#9662;
              </span>
            </button>

            <div
              id={fieldContentId(group)}
              class="optional-field-content optional-field-content--collapsed space-y-4"
              data-optional-field-content={group.id}
              hidden
            >
              <hr class="configuration-field-divider" />
              {group.description && (
                <p
                  id={fieldDescriptionId(group)}
                  class="form-message form-message--help"
                >
                  {group.description}
                </p>
              )}
              {(() => {
                switch (group.kind) {
                  case 'single-select':
                  case 'priced-single-select':
                    return (
                      <select
                        id={fieldId(group)}
                        name={group.id}
                        required={group.required}
                        class="form-control form-control--soft text-sm"
                        data-option-group={group.id}
                        data-option-kind={group.kind}
                        aria-labelledby={fieldLabelId(group)}
                        aria-describedby={describedBy(group)}
                      >
                        {!group.defaultValue && (
                          <option value="">Select an option</option>
                        )}
                        {group.options.map((option) => (
                          <option
                            value={option.value}
                            selected={group.defaultValue === option.value}
                            data-label={option.label}
                            data-price={
                              'price' in option ? option.price : undefined
                            }
                          >
                            {option.label}
                            {'price' in option
                              ? ` - ${formatAud(option.price)}`
                              : ''}
                            {option.description
                              ? ` (${option.description})`
                              : ''}
                          </option>
                        ))}
                      </select>
                    );

                  case 'multi-select':
                    return (
                      <div
                        class="option-choice-list"
                        role="group"
                        aria-labelledby={fieldLabelId(group)}
                        aria-describedby={describedBy(group)}
                        data-option-group={group.id}
                        data-option-kind={group.kind}
                        data-minimum-selections={group.minimumSelections}
                        data-maximum-selections={group.maximumSelections}
                      >
                        {group.options.map((option) => (
                          <label class="option-choice">
                            <input
                              type="checkbox"
                              name={group.id}
                              value={option.value}
                              data-label={option.label}
                              class="rounded border-slate-300"
                              aria-describedby={describedBy(group)}
                            />
                            <span>{option.label}</span>
                          </label>
                        ))}
                      </div>
                    );

                  case 'text':
                    return group.multiline ? (
                      <textarea
                        id={fieldId(group)}
                        name={group.id}
                        required={group.required}
                        maxlength={group.maxLength}
                        rows="3"
                        class="form-control form-control--soft text-sm resize-none"
                        data-option-group={group.id}
                        data-option-kind={group.kind}
                        aria-labelledby={fieldLabelId(group)}
                        aria-describedby={describedBy(group)}
                      />
                    ) : (
                      <input
                        id={fieldId(group)}
                        type="text"
                        name={group.id}
                        required={group.required}
                        maxlength={group.maxLength}
                        class="form-control form-control--soft text-sm"
                        data-option-group={group.id}
                        data-option-kind={group.kind}
                        aria-labelledby={fieldLabelId(group)}
                        aria-describedby={describedBy(group)}
                      />
                    );

                  case 'date':
                    return (
                      <input
                        id={fieldId(group)}
                        type="date"
                        name={group.id}
                        required={group.required}
                        class="form-control form-control--soft text-sm"
                        data-option-group={group.id}
                        data-option-kind={group.kind}
                        aria-labelledby={fieldLabelId(group)}
                        aria-describedby={describedBy(group)}
                      />
                    );
                }
              })()}

              {hasFieldMessage(group) && (
                <p
                  id={fieldMessageId(group)}
                  class="form-message form-message--help pt-1"
                  data-field-message={group.id}
                  aria-live="polite"
                />
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}

{
  addOns.length > 0 && (
    <section
      class="configuration-section configuration-section--add-ons"
      aria-labelledby="add-ons-heading"
    >
      <div class="configuration-section-header">
        <p class="configuration-kicker">Step 3</p>
        <h3 id="add-ons-heading" class="configuration-title">
          Optional add-ons
        </h3>
        <p class="configuration-description">
          Selected add-ons update the estimated price. Some personalised options
          are reviewed before the final quotation is confirmed.
        </p>
      </div>

      <div class="add-on-grid">
        {addOns.map(({ configuration, definition }) => {
          const price = configuration.priceOverride ?? definition.defaultPrice;
          const requiresReview =
            configuration.requiresReviewOverride ?? definition.requiresReview;
          const input = configuration.customerInput;

          return (
            <div class="add-on-choice">
              <label class="inline-flex items-start gap-3 text-sm text-slate-700">
                <input
                  type="checkbox"
                  name="addOns"
                  value={definition.id}
                  data-label={definition.name}
                  data-price={price}
                  data-requires-review={requiresReview}
                  class="mt-1 rounded border-slate-300"
                />
                <span>
                  <span class="block font-semibold text-black">
                    {definition.name} - {formatAud(price)}
                  </span>
                  <span class="block text-xs leading-relaxed text-slate-600">
                    {definition.description}
                  </span>
                  {requiresReview && (
                    <span class="mt-1 block text-xs italic text-slate-500">
                      Requires bakery review.
                    </span>
                  )}
                </span>
              </label>
              {input && (
                <div class="mt-3 hidden" data-add-on-input={definition.id}>
                  <label
                    for={`add-on-input-${definition.id}`}
                    class="text-xs font-semibold text-slate-700"
                  >
                    {input.label}
                  </label>
                  {input.kind === 'multi-line-text' ? (
                    <textarea
                      id={`add-on-input-${definition.id}`}
                      name={`addOnInput:${definition.id}`}
                      maxlength={input.maxLength}
                      rows="2"
                      class="form-control form-control--soft mt-1 text-sm resize-none"
                    />
                  ) : (
                    <input
                      id={`add-on-input-${definition.id}`}
                      type="text"
                      name={`addOnInput:${definition.id}`}
                      maxlength={input.maxLength}
                      class="form-control form-control--soft mt-1 text-sm"
                    />
                  )}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </section>
  )
}

<section
  class="configuration-review-card"
  aria-labelledby="estimated-price-heading"
>
  <div>
    <p class="configuration-kicker">Review</p>
    <h3 id="estimated-price-heading" class="configuration-title">
      Estimated Price
    </h3>
    <p class="configuration-description">
      This estimate is based on your current selections. Your final quotation
      will be confirmed after review.
    </p>
  </div>
  <p id="estimatedPrice" class="configuration-price" aria-live="polite">
    Select a size to calculate your estimate.
  </p>
</section>

{
  offering.workflowId === 'design-brief-preorder' && (
    <section
      class="configuration-section configuration-section--notice"
      aria-labelledby="reference-images-heading"
    >
      <div class="configuration-note-card">
        <h3 id="reference-images-heading" class="form-label">
          Reference Images
        </h3>
        <p class="form-message form-message--help">
          This website does not upload or store reference images. Please
          describe your idea here, then attach any reference images when your
          email client opens.
        </p>
      </div>
    </section>
  )
}
