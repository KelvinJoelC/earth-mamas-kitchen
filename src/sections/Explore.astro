---
import { EXPLORE } from "../consts/explore";
import { Image } from "astro:assets";
---

<section class="-mb-55">
    {
        EXPLORE.map(({ id, title, img, description, props }, index) => (
            <section
                style={{
                    background: `${props.bg}`,
                    transform: `translateY(calc(-100px * ${index}))`,
                    marginBottom: index === EXPLORE.length - 1 ? "100px" : "0"
                }}
                class="flex flex-col px-6 py-12 justify-center items-center rounded-t-4xl transform text-center"
            >
                <h3 class="font-calistoga text-5xl p-2 mt-6  ">{title}</h3>
                <p class="text-4xl sm:text-5xl font-dancing py-6 px-2 max-w-xl">
                    {description}
                </p>
                <a
                    href={`/products/${id}`}
                    class="inline-flex items-center justify-center px-6 py-3 bg-white text-black border border-gray-300 font-bold rounded-full hover:bg-gray-100 transition"
                >
                    View More
                </a>
                <figure class="mt-4 flex justify-center">
                    <Image
                        src={`${img}.webp`}
                        class="animate-slideIn"
                        alt="Flower cupcakes bouquet"
                        width={400}
                        height={400}
                    />
                </figure>
            </section>
        ))
    }
</section>

<style>
    @keyframes slideIn {
        0% {
            transform: translateY(0);
        }
        100% {
            transform: translateY(50px);
        }
    }

    .animate-slideIn {
        animation: slideIn 0.5s ease-in-out both;
        animation-timeline: view(50% 30%);
    }
</style>
