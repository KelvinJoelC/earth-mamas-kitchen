---
import { EXPLORE } from '@/consts/explore';
import {
  productOfferingPaths,
  serviceOfferingPaths,
} from '@/configuration/offerings/offering-paths';
import { eventsCatering } from '@/configuration/offerings/services/events-catering';
import { Image } from 'astro:assets';

const offeringImageAltText = {
  'floral-cupcake-bouquets':
    'Floral cupcake bouquet arranged as an edible gift',
  'edible-blooms': 'Decorated cupcake collection for sharing at celebrations',
  'bespoke-cakes': 'Custom celebration cake with handcrafted decoration',
} as const;
---

<section class="relative overflow-visible pb-10">
  <h2 class="sr-only">Product offerings</h2>
  {
    EXPLORE.map(
      ({ offeringId, title, img, description, props, cta }, index) => (
        <section
          style={{
            background: `${props.bg}`,
            marginTop: index === 0 ? '0' : '-100px',
            zIndex: index + 1,
          }}
          class="relative flex flex-col px-6 py-12 justify-center items-center rounded-t-4xl transform overflow-visible text-center"
        >
          <h3 class="font-calistoga text-5xl p-2 mt-6  ">{title}</h3>
          <p class="text-4xl sm:text-5xl font-dancing py-6 px-2 max-w-xl">
            {description}
          </p>
          <a
            href={productOfferingPaths[offeringId]}
            class="inline-flex items-center justify-center px-6 py-3 bg-white text-black border border-gray-300 font-bold rounded-full hover:bg-gray-100 transition"
          >
            {cta ?? 'Start Preorder'}
          </a>
          <figure class="mt-4 flex justify-center">
            <Image
              src={`${img}.webp`}
              class="animate-slideIn"
              alt={offeringImageAltText[offeringId]}
              transition:name={`offering-image-${offeringId}`}
              width={400}
              height={400}
            />
          </figure>
        </section>
      ),
    )
  }
  <section
    style={{
      background:
        'linear-gradient(135deg, white 0%, #f8d7e6 28%, #dba2b1 58%, #a89bc0 82%, white 100%)',
      marginTop: '-100px',
      zIndex: EXPLORE.length + 1,
    }}
    class="relative flex flex-col px-6 py-12 justify-center items-center rounded-t-4xl transform overflow-visible text-center"
  >
    <h3 class="font-calistoga text-5xl p-2 mt-6">
      {eventsCatering.name}
    </h3>
    <p class="text-4xl sm:text-5xl font-dancing py-6 px-2 max-w-xl">
      Large events, catering requests and complex celebrations are handled
      through a personal enquiry, not the standard preorder flow.
    </p>
    <a
      href={serviceOfferingPaths[eventsCatering.id]}
      class="inline-flex items-center justify-center px-6 py-3 bg-white text-black border border-gray-300 font-bold rounded-full hover:bg-gray-100 transition"
    >
      Plan Your Event
    </a>
    <figure class="mt-4 flex justify-center">
      <Image
        src="/images/events.webp"
        class="animate-slideIn"
        alt="Earth Mama’s Kitchen events and catering presentation"
        transition:name={`service-image-${eventsCatering.id}`}
        width={400}
        height={400}
      />
    </figure>
  </section>
</section>
