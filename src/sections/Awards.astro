---
import { AWARDS } from '@/content/awards';
---

<section
  class="text-black py-6"
  style="background: radial-gradient(circle at center, #ffffff, #f6f3e7);"
>
  <div class="marquee-horizontal">
    <div class="h-full overflow-hidden px-0 whitespace-nowrap">
      <span
        class="font-dancing marquee-font font-bold will-change-transform animate-marquee-horizontal inline-flex items-center select-none"
      >
        {Array(8).fill('Awards •').join(' ')}
      </span>
    </div>
  </div>
  <div class="flex justify-center px-6 pb-3">
    <button
      type="button"
      class="carousel-toggle"
      data-carousel-toggle
      aria-pressed="false"
    >
      Pause awards carousel
    </button>
  </div>
  <div
    class="embla autoplayCarousel overflow-hidden w-full"
    role="region"
    aria-label="Awards carousel"
  >
    <div class="embla__container flex">
      {
        AWARDS.map(({ id, event, position, description, title }) => (
          <div class="embla__slide min-w-0 basis-full flex-none">
            <div class="card flex flex-col relative w-full h-full ">
              <div class="p-6 lg:p-0  text-center">
                <h3 class="text-2xl font-bold mb-2">{event}</h3>
                <img
                  src={`/images/${id}.webp`}
                  alt="Award"
                  class="w-30 h-30 mx-auto "
                />
                <h3 class="text-3xl font-bold">{position}</h3>
                <h3 class="text-lg font-bold mb-1">{title}</h3>
                <p class="text-sm px-6">{description}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import '@/browser/carousel.js';
</script>
