---
import InstagramIcon from '@/assets/instagram.svg';
import FacebookIcon from '@/assets/facebook.svg';
---

<section
  aria-labelledby="general-contact-heading"
  class="flex flex-col items-center pt-20 rounded-b-4xl rounded-t-2xl transform -translate-y-15 min-h-screen bg-gradient-to-b from-[#1E3A8A] to-[#1E40AF] text-white p-4 mt-15"
>
  <div class="social-links-surface">
    <a
      href="https://www.instagram.com/earthmamaskitchen"
      target="_blank"
      rel="noopener noreferrer"
      class="ui-icon-link ui-icon-link--social"
      aria-label="Visit Earth Mama's Kitchen on Instagram"
    >
      <InstagramIcon class="size-5" />
    </a>
    <a
      href="https://www.facebook.com/profile.php?id=100067897911008"
      target="_blank"
      rel="noopener noreferrer"
      class="ui-icon-link ui-icon-link--social"
      aria-label="Visit Earth Mama's Kitchen on Facebook"
    >
      <FacebookIcon class="size-5" />
    </a>
  </div>
  <div
    class="flex flex-row flex-wrap items-center justify-center gap-3 w-full max-w-md p-4 mb-4"
  >
    <img
      src="/favicon.png"
      alt="Earth Mama kitchen"
      width="300"
      height="348"
      loading="lazy"
      decoding="async"
      class="size-20"
    />
    <h2 id="general-contact-heading" class="text-3xl font-bold">
      Earth Mama`s Kitchen
    </h2>
  </div>
  <h3 class="font-merienda text-3xl">Bake like you mean it.</h3>
  <p class="text-2xl text-center mb-4 w-4/5">
    Contact me for general questions or to talk cake. For preorder requests,
    please use the product pages so your configuration can be reviewed properly.
  </p>
  <form id="generalContactForm" class="w-full" novalidate>
    <div
      class="flex flex-col gap-3 p-4 rounded-lg shadow-lg w-full max-w-md mx-auto"
    >
      <p class="text-sm text-white/85">
        This form prepares a general enquiry email in your own email client.
        Please review and send it manually. Your details are not stored by this
        website.
      </p>

      <div class="grid gap-[0.35rem]">
        <label for="contact-name" class="text-[0.95rem] font-bold">Name *</label
        >
        <input
          id="contact-name"
          name="name"
          required
          type="text"
          autocomplete="name"
          placeholder="Your name"
          class="form-control"
          aria-describedby="contact-name-error"
        />
        <p
          id="contact-name-error"
          class="min-h-4 text-[0.8rem] font-bold text-red-200"
        >
        </p>
      </div>

      <div class="grid gap-[0.35rem]">
        <label for="contact-email" class="text-[0.95rem] font-bold"
          >Email *</label
        >
        <input
          id="contact-email"
          name="email"
          required
          type="email"
          autocomplete="email"
          placeholder="you@example.com"
          class="form-control"
          aria-describedby="contact-email-error"
        />
        <p
          id="contact-email-error"
          class="min-h-4 text-[0.8rem] font-bold text-red-200"
        >
        </p>
      </div>

      <div class="grid gap-[0.35rem]">
        <label for="contact-phone" class="text-[0.95rem] font-bold">
          Phone <span class="font-normal text-white/80">(optional)</span>
        </label>
        <input
          id="contact-phone"
          name="phone"
          type="tel"
          autocomplete="tel"
          placeholder="Optional phone number"
          class="form-control"
          aria-describedby="contact-phone-help"
        />
        <p id="contact-phone-help" class="text-[0.8rem] text-white/80">
          Optional. Include this only if you are happy to be contacted by phone.
        </p>
      </div>

      <div class="grid gap-[0.35rem]">
        <label for="contact-message" class="text-[0.95rem] font-bold"
          >Message *</label
        >
        <textarea
          id="contact-message"
          name="message"
          required
          maxlength="1000"
          rows="6"
          placeholder="How can we help?"
          class="form-control"
          aria-describedby="contact-message-help contact-message-error"
        ></textarea>
        <p id="contact-message-help" class="text-[0.8rem] text-white/80">
          Maximum 1,000 characters.
        </p>
        <p
          id="contact-message-error"
          class="min-h-4 text-[0.8rem] font-bold text-red-200"
        >
        </p>
      </div>

      <div
        id="generalContactStatus"
        class="empty:hidden rounded-xl bg-white/12 p-3 text-sm font-semibold data-[status=error]:bg-red-50 data-[status=error]:text-red-800 data-[status=success]:bg-emerald-50 data-[status=success]:text-emerald-800"
        role="status"
        aria-live="polite"
      >
      </div>

      <textarea
        id="generalContactFallback"
        class="form-control min-h-56 resize-y"
        readonly
        hidden
        aria-label="Prepared general enquiry email"></textarea>

      <div class="grid gap-3">
        <button type="submit" class="ui-button ui-button--primary">
          Prepare Email
        </button>
        <button
          id="copyGeneralContactMessage"
          type="button"
          class="ui-button ui-button--secondary"
        >
          Copy message
        </button>
      </div>
    </div>
  </form>
</section>

<script>
  import '@/browser/contact-form.js';
</script>
