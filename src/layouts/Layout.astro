---
import '@/styles/global.css';
import Footer from '@/sections/Footer.astro';
import Header from '@/sections/Header.astro';
import { ClientRouter } from 'astro:transitions';
import StickyOrderButton from '@/components/StickyOrderButton.astro';

interface Props {
  title?: string;
  description?: string;
  showStickyOrderButton?: boolean;
}

const defaultTitle =
  'Earth Mamas Kitchen | Specialising in Floral Cupcake Bouquets and Bespoke Cakes 🎂 Scratch Baking 🍄 Edible Blooms and Art for any occasion 🌻 Love in every bite ❤️💋';
const defaultDescription =
  'Earth Mamas Kitchen | Specialising in Floral Cupcake Bouquets and Bespoke Cakes 🎂 Scratch Baking 🍄 Edible Blooms and Art for any occasion 🌻 Love in every bite ❤️💋';

const {
  title = defaultTitle,
  description = defaultDescription,
  showStickyOrderButton = true,
} = Astro.props;

const pageTitle =
  title === defaultTitle ? title : `${title} | Earth Mama's Kitchen`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <ClientRouter />
  </head>
  <body
    class="m-0 w-full min-h-screen flex flex-col custom-gradient text-white"
  >
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>
    {
      showStickyOrderButton && (
        <StickyOrderButton class="fixed bottom-6 right-6" />
      )
    }
    <Footer />
  </body>
</html>

<style>
  .custom-gradient {
    background: linear-gradient(
      10deg,
      var(--violeta-oscuro) 0%,
      var(--violeta-medio) 25%,
      var(--verde-azulado-claro) 50%,
      var(--verde-claro) 75%,
      var(--verde-oscuro) 100%
    );
  }
</style>
