---
import '@/styles/global.css';
import Footer from '@/sections/Footer.astro';
import Header from '@/sections/Header.astro';
import { ClientRouter } from 'astro:transitions';
import StickyOrderButton from '@/components/StickyOrderButton.astro';
import { siteMetadata, type PageMetadata } from '@/configuration/metadata';

interface Props {
  metadata: PageMetadata;
  showStickyOrderButton?: boolean;
  showCartLink?: boolean;
}

const {
  metadata,
  showStickyOrderButton = true,
  showCartLink = true,
} = Astro.props;

if (!Astro.site) {
  throw new Error('Missing Astro site configuration for SEO metadata.');
}

const pageTitle =
  metadata.title === siteMetadata.name
    ? metadata.title
    : `${metadata.title} | ${siteMetadata.name}`;
const canonicalUrl = new URL(metadata.canonicalPath, Astro.site).toString();
const socialImage = metadata.image ?? siteMetadata.defaultImage;
const socialImageUrl = new URL(socialImage.src, Astro.site).toString();
const robotsContent = metadata.noindex ? 'noindex, follow' : 'index, follow';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{pageTitle}</title>
    <meta name="description" content={metadata.description} />
    <meta name="robots" content={robotsContent} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metadata.description} />
    <meta property="og:type" content={metadata.type ?? 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={socialImage.alt} />
    <meta property="og:site_name" content={siteMetadata.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metadata.description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={socialImage.alt} />
    <ClientRouter />
  </head>
  <body
    class="m-0 w-full min-h-screen flex flex-col custom-gradient text-white"
  >
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header showCartLink={showCartLink} />
    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>
    {
      showStickyOrderButton && (
        <StickyOrderButton class="fixed bottom-6 right-6" />
      )
    }
    <Footer />
  </body>
</html>

<style>
  .custom-gradient {
    background: linear-gradient(
      10deg,
      var(--violeta-oscuro) 0%,
      var(--violeta-medio) 25%,
      var(--verde-azulado-claro) 50%,
      var(--verde-claro) 75%,
      var(--verde-oscuro) 100%
    );
  }
</style>
