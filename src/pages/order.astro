---
import InstagramIcon from '@/assets/instagram.svg';
import FacebookIcon from '@/assets/facebook.svg';
import Layout from '@/layouts/Layout.astro';
import '@/styles/cart.css';
import RelatedProducts from '@/sections/RelatedProducts.astro';
import { EXPLORE } from '@/consts/explore';
---

<Layout title="Order" description="Place your order with Earth Mama's Kitchen">
  <section class="w-full flex flex-col items-center">
    <!--  bg-gradient-to-b from-[#1E3A8A] to-[#1E40AF]-->
    <div class="flex justify-center pt-20">
      <div class="social-links-surface">
        <a
          href="https://www.instagram.com/earthmamaskitchen"
          target="_blank"
          rel="noopener noreferrer"
          class="ui-icon-link ui-icon-link--social"
        >
          <InstagramIcon class="size-5" />
        </a>
        <a
          href="https://www.facebook.com/profile.php?id=100067897911008"
          target="_blank"
          rel="noopener noreferrer"
          class="ui-icon-link ui-icon-link--social"
        >
          <FacebookIcon class="size-5" />
        </a>
      </div>
    </div>
    <div class="flex flex-col items-center justify-center p-4 mb-4 gap-1">
      <h2 class="text-3xl font-bold">Earth Mama Kitchen</h2>
      <h3 class="font-merienda text-3xl">Bake like you mean it.</h3>
    </div>
  </section>
  <section id="cart-resumen" class="w-full p-3 mb-5">
    <div class="flex flex-col items-start w-full bg-white p-4 shadow-lg">
      <div class="cart-summary-header">
        <div>
          <h1 class="text-3xl text-black font-medium">Summary</h1>
          <p
            id="cartCountSummary"
            class="cart-count-summary"
            aria-live="polite"
          >
            Loading saved preorder configurations...
          </p>
        </div>
        <button id="clearBtn" type="button" class="cart-clear-button" hidden>
          Clear cart
        </button>
      </div>
      <div
        id="cartRoot"
        class="flex flex-col w-full gap-2 mt-2"
        aria-live="polite"
      >
      </div>
    </div>
  </section>
  <RelatedProducts selection={EXPLORE} />

  <section
    id="orderSubmission"
    class="flex flex-col items-center rounded-4xl transform -translate-y-10 bg-gradient-to-b from-[#1E3A8A] to-[#1E40AF] text-white p-4"
    hidden
  >
    <img
      src="/favicon.png"
      alt="Earth mama's kitchen"
      class="size-30 p-2 m-2 rounded-full border-4 border-[#78698C] bg-white/10"
    />
    <h2 class="text-2xl font-bold mb-2">Confirm Your Order</h2>
    <p class="mb-4 text-center">
      Complete the preorder request with your name, phone number and collection
      preference. Your email client will open with a prepared message for you to
      review and send manually.
    </p>
    <form id="contactForm" class="w-full p-2 flex flex-col gap-2">
      <input
        required
        type="text"
        name="name"
        autocomplete="name"
        maxlength="80"
        placeholder="Full name"
        class="form-control"
      />
      <input
        required
        type="tel"
        name="phone"
        maxlength="10"
        inputmode="numeric"
        autocomplete="tel"
        pattern="04[0-9]{8}"
        placeholder="Australian mobile e.g. 0412345678"
        class="form-control"
      />
      <select required name="collectionPreference" class="form-control">
        <option value="">Select collection preference</option>
        <option value="Weekday morning pickup, 9am-12pm">
          Weekday morning pickup, 9am-12pm
        </option>
        <option value="Weekday afternoon pickup, 12pm-4pm">
          Weekday afternoon pickup, 12pm-4pm
        </option>
        <option value="Flexible pickup time"> Flexible pickup time </option>
      </select>
      <div
        id="preorderEmailStatus"
        class="preorder-email-status"
        role="status"
        aria-live="polite"
      >
      </div>
      <textarea
        id="preorderEmailFallback"
        class="preorder-email-fallback"
        readonly
        hidden
        aria-label="Prepared preorder email"></textarea>
      <div class="preorder-email-actions">
        <button type="submit" class="ui-button ui-button--primary">
          Prepare Email
        </button>
        <button
          id="copyPreorderEmail"
          type="button"
          class="ui-button ui-button--secondary"
        >
          Copy preorder email
        </button>
      </div>
    </form>
  </section>
</Layout>

<script>
  import '@/browser/order-form.js';
</script>
