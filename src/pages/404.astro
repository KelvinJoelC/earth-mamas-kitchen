---
import Layout from '@/layouts/Layout.astro';
import type { PageMetadata } from '@/configuration/metadata';

const metadata = {
  title: 'Page Not Found',
  description:
    "The page you were looking for is not available on Earth Mama's Kitchen.",
  canonicalPath: '/404',
  noindex: true,
} as const satisfies PageMetadata;
---

<Layout metadata={metadata} showStickyOrderButton={false}>
  <section
    class="mx-auto flex min-h-[60vh] max-w-3xl flex-col items-center justify-center px-6 py-24 text-center"
    aria-labelledby="not-found-title"
  >
    <p class="text-sm font-bold uppercase tracking-[0.24em] text-white/75">
      404
    </p>
    <h1
      id="not-found-title"
      class="mt-4 font-calistoga text-5xl text-white sm:text-6xl"
    >
      Page not found
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-white/85">
      The page may have moved, or the link may no longer be part of this
      portfolio case study. You can return to the homepage to continue browsing
      the available Product Offerings and enquiry pathways.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center justify-center rounded-full border border-white/40 bg-white px-6 py-3 font-bold text-slate-950 transition hover:bg-white/90"
    >
      Back to homepage
    </a>
  </section>
</Layout>
