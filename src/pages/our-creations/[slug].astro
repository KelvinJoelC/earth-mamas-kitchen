---
import { productOfferings } from '@/configuration/offerings/product-offerings';
import { EXPLORE } from '@/consts/explore';
import Layout from '@/layouts/Layout.astro';
import { OPTION_LABELS, type Product } from '@/models/product.model';
import PreOrderFeaturesSelector from '@/components/PreOrderFeaturesSelector.astro';
import { Image } from 'astro:assets';
import type { ProductOfferingDefinition } from '@/domain/offerings';
import { businessRules } from '@/configuration/rules/rules';
import {
  allergenCatalogue,
  allergenPolicy,
} from '@/configuration/catalogues/allergens';
import { cupcakeFlavourCatalogue } from '@/configuration/catalogues/cupcake-flavours';
import { spongeFlavourCatalogue } from '@/configuration/catalogues/sponge-flavours';
import { fillingCatalogue } from '@/configuration/catalogues/fillings';
import { frostingCatalogue } from '@/configuration/catalogues/frostings';
import { addOnAllergenProfiles } from '@/configuration/catalogues/add-on-allergen-profiles';
import { addOnCatalogue } from '@/configuration/catalogues/add-ons';

export function getStaticPaths() {
  return productOfferings.map((offering) => {
    const selection = EXPLORE.find(
      ({ offeringId }) => offeringId === offering.id,
    );

    if (!selection) {
      throw new Error(`Missing presentation data for ${offering.id}.`);
    }

    return {
      params: { slug: offering.slug },
      props: { offering, selection },
    };
  });
}

const { offering, selection } = Astro.props as {
  offering: ProductOfferingDefinition;
  selection: Product;
};

const selectedRules = businessRules.filter((rule) =>
  offering.ruleIds.includes(rule.id),
);

const edibleOptionCatalogues = [
  cupcakeFlavourCatalogue,
  spongeFlavourCatalogue,
  fillingCatalogue,
  frostingCatalogue,
].flat();

const optionAllergens = Object.fromEntries(
  edibleOptionCatalogues.map((item) => [item.id, item.allergens.contains]),
);

const addOns = offering.addOns.map((configuration) => {
  const definition = addOnCatalogue.find(
    ({ id }) => id === configuration.addOnId,
  );

  return {
    ...configuration,
    name: definition?.name ?? configuration.addOnId,
    price: configuration.priceOverride ?? definition?.defaultPrice ?? 0,
    requiresReview:
      configuration.requiresReviewOverride ??
      definition?.requiresReview ??
      false,
    allergens:
      configuration.addOnId in addOnAllergenProfiles
        ? addOnAllergenProfiles[
            configuration.addOnId as keyof typeof addOnAllergenProfiles
          ].contains
        : [],
  };
});

const preorderConfig = {
  offeringId: offering.id,
  offeringName: offering.name,
  workflowId: offering.workflowId,
  leadTime: offering.leadTime,
  optionGroups: offering.optionGroups,
  addOns,
  rules: selectedRules,
  optionAllergens,
  allergenLabels: Object.fromEntries(
    allergenCatalogue.map((allergen) => [allergen.id, allergen.label]),
  ),
  allergenPolicy,
};

const preorderConfigJson = JSON.stringify(preorderConfig);
---

<Layout title={selection.title} description={selection.description}>
  <section
    class="product-page-shell flex flex-col items-center justify-center pt-30 lg:pt-20 gap-12 text-center"
    style={{ background: selection.props.bg }}
  >
    <div class="product-hero-layout">
      <div class="product-hero-media">
        <Image
          src={`${selection.img}.webp`}
          class="product-hero-image"
          alt={selection.title}
          transition:name={`offering-image-${offering.id}`}
          width={420}
          height={420}
          sizes="(min-width: 768px) min(37vw, 25rem), min(90vw, 25rem)"
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <div class="product-hero-content">
        <div class="product-hero-summary">
          <p class="configuration-kicker">Made to order</p>
          <h1 class="font-calistoga text-5xl lg:text-6xl leading-tight">
            {selection.title}
          </h1>
          <div class="product-hero-description-card">
            <p class="product-hero-description">
              {selection.description}
            </p>
          </div>
          <div class="product-hero-guide">
            <span aria-hidden="true">1</span>
            <p>Choose your options</p>
            <span aria-hidden="true">2</span>
            <p>Review your estimate</p>
            <span aria-hidden="true">3</span>
            <p>Save to cart</p>
          </div>
        </div>

        <details class="product-info-disclosure">
          <summary
            class="flex cursor-pointer items-center justify-between gap-4 text-lg font-semibold text-black transition hover:text-violeta-oscuro"
          >
            <span>{OPTION_LABELS['allergens']}</span>
            <span aria-hidden="true">&#9662;</span>
          </summary>
          <div class="pt-4 text-sm text-slate-700">
            <p>
              <span id="containsAllergens" aria-live="polite">
                <strong>
                  Select your flavours to view the allergen information.
                </strong>
              </span>
            </p>
          </div>
        </details>
      </div>
    </div>

    <div class="product-configurator-page w-full text-black">
      <form
        id="preOrderForm"
        method="POST"
        data-product-title={selection.title}
        data-offering-id={offering.id}
        data-workflow-id={offering.workflowId}
        data-preorder-config={preorderConfigJson}
        class="text-black w-full"
      >
        <PreOrderFeaturesSelector offering={offering} />

        <section
          class="configuration-section configuration-section--notice"
          aria-labelledby="allergen-notice-heading"
        >
          <div class="configuration-note-card">
            <h3 id="allergen-notice-heading" class="form-label">
              Important Allergen Notice
            </h3>
            <p
              id="crossContaminationWarning"
              class="form-message form-message--help"
            >
              {allergenPolicy.crossContaminationWarning}
            </p>
          </div>
        </section>

        <section class="configuration-action-section">
          <div class="configuration-actions">
            <button
              type="reset"
              class="ui-button min-h-11 text-sm px-5 py-2 rounded-full border border-slate-200 text-slate-500 hover:bg-slate-50"
            >
              Clean
            </button>

            <button
              type="submit"
              class="ui-button min-h-11 text-sm px-6 py-2 rounded-full bg-green-500 text-white font-semibold hover:bg-verde-medio shadow-sm"
            >
              Confirm
            </button>
          </div>
        </section>
      </form>
    </div>
  </section>
</Layout>

<script>
  import '@/browser/preorder-form.js';
</script>
