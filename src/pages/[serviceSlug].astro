---
import { serviceOfferings } from '@/configuration/offerings/service-offerings';
import FormFieldShell from '@/components/FormFieldShell.astro';
import Layout from '@/layouts/Layout.astro';
import type { ServiceOfferingDefinition } from '@/domain/offerings';
import { getServiceOfferingMetadata } from '@/configuration/metadata';

export function getStaticPaths() {
  return serviceOfferings.map((offering) => ({
    params: { serviceSlug: offering.slug },
    props: { offering },
  }));
}

const { offering } = Astro.props as {
  offering: ServiceOfferingDefinition;
};

const metadata = getServiceOfferingMetadata(offering);
---

<Layout metadata={metadata}>
  <section class="service-page-shell">
    <div class="service-hero">
      <div class="service-hero-content">
        <p class="configuration-kicker">Custom enquiry pathway</p>
        <h1 class="font-calistoga text-5xl leading-tight sm:text-6xl">
          {offering.name}
        </h1>
        <p class="service-hero-summary">{offering.summary}</p>
        <p class="service-hero-note">
          This is an initial enquiry pathway. Availability, requirements and
          final pricing are confirmed personally after consultation.
        </p>
      </div>

      <div
        class="service-hero-panel"
        aria-label="Events and catering enquiry overview"
      >
        <div>
          <span aria-hidden="true">1</span>
          <p>Share your event idea</p>
        </div>
        <div>
          <span aria-hidden="true">2</span>
          <p>Prepare your enquiry email</p>
        </div>
        <div>
          <span aria-hidden="true">3</span>
          <p>Confirm details personally</p>
        </div>
      </div>
    </div>

    <form id="eventsCateringForm" class="service-enquiry-form" novalidate>
      <div class="service-form-intro">
        <p class="configuration-kicker">Start the conversation</p>
        <h2 class="configuration-title">Request a personalised consultation</h2>
        <p class="configuration-description">
          This form prepares an Events & Catering enquiry email in your own
          email client. Please review and send it manually. Sending the enquiry
          does not confirm availability, pricing or booking.
        </p>
      </div>

      <div class="configuration-grid service-form-grid">
        <FormFieldShell label="Name" forId="event-name" required>
          <input
            id="event-name"
            name="name"
            required
            maxlength="100"
            type="text"
            autocomplete="name"
            class="form-control form-control--soft text-sm"
            aria-describedby="event-name-error"
          />
          <p
            id="event-name-error"
            class="form-message form-message--error min-h-4"
          >
          </p>
        </FormFieldShell>

        <FormFieldShell label="Email" forId="event-email" required>
          <input
            id="event-email"
            name="email"
            required
            maxlength="254"
            type="email"
            autocomplete="email"
            class="form-control form-control--soft text-sm"
            aria-describedby="event-email-error"
          />
          <p
            id="event-email-error"
            class="form-message form-message--error min-h-4"
          >
          </p>
        </FormFieldShell>

        <FormFieldShell label="Phone Number" forId="event-phone" required>
          <input
            id="event-phone"
            name="phone"
            required
            maxlength="30"
            type="tel"
            autocomplete="tel"
            class="form-control form-control--soft text-sm"
            aria-describedby="event-phone-help event-phone-error"
          />
          <p id="event-phone-help" class="form-message form-message--help">
            Used only so the bakery can contact you personally about the
            enquiry.
          </p>
          <p
            id="event-phone-error"
            class="form-message form-message--error min-h-4"
          >
          </p>
        </FormFieldShell>

        <FormFieldShell label="Event Type" forId="event-type" required>
          <select
            id="event-type"
            name="eventType"
            required
            class="form-control form-control--soft text-sm"
            aria-describedby="event-type-error"
          >
            <option value="">Select an option</option>
            <option value="Wedding">Wedding</option>
            <option value="Corporate Event">Corporate Event</option>
            <option value="Birthday">Birthday</option>
            <option value="Baby Shower">Baby Shower</option>
            <option value="Anniversary">Anniversary</option>
            <option value="Community Event">Community Event</option>
            <option value="Other">Other</option>
          </select>
          <p
            id="event-type-error"
            class="form-message form-message--error min-h-4"
          >
          </p>
        </FormFieldShell>

        <FormFieldShell
          label="Preferred Event Date"
          forId="preferred-event-date"
          optionalLabel="(optional)"
        >
          <input
            id="preferred-event-date"
            name="preferredEventDate"
            type="date"
            class="form-control form-control--soft text-sm"
          />
        </FormFieldShell>

        <FormFieldShell
          label="Message"
          forId="event-message"
          required
          class="service-field--message"
        >
          <textarea
            id="event-message"
            name="message"
            required
            maxlength="1000"
            rows="6"
            class="form-control form-control--soft resize-none text-sm"
            placeholder="Briefly describe your event, initial ideas and anything important."
            aria-describedby="event-message-help event-message-error"
          ></textarea>
          <p id="event-message-help" class="form-message form-message--help">
            Maximum 1,000 characters.
          </p>
          <p
            id="event-message-error"
            class="form-message form-message--error min-h-4"
          >
          </p>
        </FormFieldShell>
      </div>

      <div
        id="eventsCateringStatus"
        class="service-status empty:hidden rounded-xl bg-slate-100 p-3 text-sm font-semibold data-[status=error]:bg-red-50 data-[status=error]:text-red-800 data-[status=success]:bg-emerald-50 data-[status=success]:text-emerald-800"
        role="status"
        aria-live="polite"
      >
      </div>

      <textarea
        id="eventsCateringFallback"
        class="form-control form-control--soft service-fallback min-h-56 resize-y"
        readonly
        hidden
        aria-label="Prepared Events and Catering enquiry email"></textarea>

      <div class="service-actions flex flex-wrap justify-end gap-3">
        <button type="submit" class="ui-button ui-button--primary">
          Prepare Email
        </button>
        <button
          id="copyEventsCateringMessage"
          type="button"
          class="ui-button ui-button--secondary"
        >
          Copy message
        </button>
      </div>
    </form>
  </section>
</Layout>

<script>
  import '@/browser/events-catering-form.js';
</script>

<style>
  .service-page-shell {
    overflow: hidden;
    background:
      radial-gradient(
        circle at 12% 10%,
        rgb(253 224 233 / 54%),
        transparent 28rem
      ),
      radial-gradient(
        circle at 88% 24%,
        rgb(233 213 255 / 32%),
        transparent 26rem
      ),
      linear-gradient(180deg, rgb(255 250 252 / 92%), rgb(255 255 255));
    color: var(--ui-color-text-default);
    text-align: left;
  }

  .service-hero {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    width: min(100% - 3rem, 72rem);
    margin-inline: auto;
    padding-block: clamp(7rem, 12vw, 10rem) clamp(3.5rem, 8vw, 6rem);
  }

  .service-hero-content {
    display: grid;
    gap: var(--ui-space-4);
    max-width: 45rem;
  }

  .service-hero-summary {
    max-width: 42rem;
    color: rgb(30 41 59);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.45;
  }

  .service-hero-note {
    max-width: 38rem;
    border-left: 4px solid rgb(190 24 93);
    padding-left: var(--ui-space-4);
    color: var(--ui-color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .service-hero-panel {
    display: grid;
    gap: var(--ui-space-3);
    align-self: end;
    border: 1px solid rgb(255 255 255 / 72%);
    border-radius: clamp(1.75rem, 4vw, 2.75rem);
    background: rgb(255 255 255 / 78%);
    padding: clamp(1.25rem, 3vw, 2rem);
    box-shadow: 0 20px 60px rgb(15 23 42 / 8%);
    backdrop-filter: blur(10px);
  }

  .service-hero-panel div {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--ui-space-3);
    align-items: center;
  }

  .service-hero-panel span {
    display: inline-grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border-radius: var(--ui-radius-pill);
    background: rgb(190 24 93);
    color: #ffffff;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .service-hero-panel p {
    color: rgb(51 65 85);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .service-enquiry-form {
    display: grid;
    gap: clamp(1.25rem, 3vw, 2rem);
    width: 100%;
    padding-block: clamp(3.5rem, 8vw, 6.5rem);
    background:
      radial-gradient(
        circle at 84% 18%,
        rgb(249 168 212 / 18%),
        transparent 24rem
      ),
      linear-gradient(180deg, rgb(255 255 255 / 95%), rgb(255 247 250 / 78%));
  }

  .service-form-intro,
  .service-form-grid,
  .service-status,
  .service-fallback,
  .service-actions {
    width: min(100% - 3rem, 72rem);
    margin-inline: auto;
  }

  .service-form-intro {
    display: grid;
    gap: var(--ui-space-2);
  }

  .service-form-grid {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .service-field--message {
    min-height: 100%;
  }

  @media (min-width: 768px) {
    .service-hero {
      grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
      align-items: end;
    }

    .service-form-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .service-field--message {
      grid-column: 1 / -1;
    }
  }
</style>
